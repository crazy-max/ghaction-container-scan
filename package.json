{
  "name": "container-scan",
  "description": "Check for vulnerabilities in your container image",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.cjs --sourcemap --minify && yarn run license",
    "lint": "yarn run eslint",
    "format": "yarn run eslint:fix",
    "test": "vitest run",
    "license": "generate-license-file --input package.json --output dist/licenses.txt --overwrite --ci --no-spinner --eol lf",
    "all": "yarn run build && yarn run format && yarn test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crazy-max/ghaction-container-scan.git"
  },
  "keywords": [
    "actions",
    "docker",
    "scan",
    "vulnerabilities",
    "trivy"
  ],
  "author": "CrazyMax",
  "license": "MIT",
  "packageManager": "yarn@4.17.0",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/http-client": "^4.0.0",
    "@actions/tool-cache": "^4.0.0",
    "chalk": "^5.6.2",
    "lodash.truncate": "^4.4.2",
    "semver": "^7.8.5",
    "tmp": "^0.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/lodash.truncate": "^4.4.9",
    "@types/node": "^25.2.3",
    "@types/semver": "^7.7.1",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.9",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "generate-license-file": "^4.1.1",
    "globals": "^14.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
